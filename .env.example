# Copy to `.env` and fill in. The Google Maps key is the only secret on the client
# (it must be, since the Maps SDK runs in the browser) — restrict it in Google Cloud
# Console. All other secrets live in server/.env.

REACT_APP_GOOGLE_MAPS_API_KEY=your-google-maps-key
REACT_APP_SERVER_URL=http://localhost:4000

# --- Memories: Firebase auth (Google sign-in). OPTIONAL: if these are blank, the app runs
# in DEV AUTH mode (a fake local user, no real login) so Memories still work locally.
# Fill them from your Firebase project → Project settings → "Your apps" (web app config). ---
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_APP_ID=

# --- Memories: Cloudinary photo upload. OPTIONAL: if blank, photos preview locally but
# don't persist. Cloud name = Cloudinary dashboard; upload preset = Settings → Upload →
# add an UNSIGNED preset. ---
REACT_APP_CLOUDINARY_CLOUD_NAME=
REACT_APP_CLOUDINARY_UPLOAD_PRESET=
