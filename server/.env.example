# Copy this file to `.env` and fill in real values. Never commit `.env`.

# Port the server listens on
PORT=4000

# MongoDB connection string.
# - Local:  mongodb://127.0.0.1:27017/travel_advisor
# - Atlas:  mongodb+srv://<user>:<pass>@<cluster>/travel_advisor
# Leave BLANK to run with an in-memory store (data is lost on restart) — handy for
# trying things out without installing MongoDB.
MONGODB_URI=

# Where the React app runs, for CORS. Default matches Create React App.
CLIENT_ORIGIN=http://localhost:3000

# RapidAPI key for the Travel Advisor places API. Lives ONLY here on the server so it's
# never exposed in the browser bundle. Get one at https://rapidapi.com/
RAPIDAPI_KEY=

# Firebase Admin service account (for verifying Memories auth tokens). Paste the WHOLE
# service-account JSON as a single line. OPTIONAL: if blank, the Memories API runs in DEV
# AUTH mode (trusts an `x-dev-user` header) so it works locally without Firebase.
# Get it from Firebase Console → Project settings → Service accounts → Generate new private key.
FIREBASE_SERVICE_ACCOUNT=

# Cloudinary credentials for DELETING memory photos (uploads are unsigned from the browser;
# deletes need the secret, which must stay server-side). From the Cloudinary dashboard.
# OPTIONAL: if blank, removing a photo still deletes the DB record but leaves the file on
# Cloudinary (an orphan). Set these to delete the actual files too.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
